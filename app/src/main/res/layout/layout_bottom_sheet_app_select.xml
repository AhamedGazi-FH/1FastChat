<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Message number"
        android:textColor="#757575"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvDialogNumber"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:textColor="#111111"
        android:textSize="24sp"
        android:textStyle="bold"
        tools:text="+91 9876543210" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilDialogMessage"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:hint="Pre-fill a message (Optional)"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusTopStart="12dp"
        app:boxStrokeColor="#25D366"
        app:hintTextColor="#25D366">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etDialogMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine"
            android:maxLines="3" />
    </com.google.android.material.textfield.TextInputLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:scrollbars="none">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/dialogTemplateChipGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleLine="true" />
    </HorizontalScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDialogWhatsApp"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:elevation="0dp"
            android:text="WhatsApp"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#25D366"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDialogBusiness"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:elevation="0dp"
            android:text="Business"
            android:textAllCaps="false"
            android:textColor="#075E54"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#E8F9EE"
            app:cornerRadius="12dp" />
    </LinearLayout>
</LinearLayout>